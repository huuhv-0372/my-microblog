<div class="max-w-5xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-1">
    Posts tagged <span class="text-indigo-600">"{{tag.name}}"</span>
  </h1>
  <p class="text-sm text-gray-500 mb-6">{{pagination.total}} post{{#unless (eq pagination.total 1)}}s{{/unless}} found</p>

  {{#if posts.length}}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
      {{#each posts}}
        {{> post-card}}
      {{/each}}
    </div>
    {{> pagination pagination=pagination}}
  {{else}}
    <div class="text-center py-16 text-gray-400">
      <p class="text-lg">No published posts for this tag yet.</p>
      <a href="/" class="text-sm text-indigo-500 hover:underline mt-2 inline-block">← Back to home</a>
    </div>
  {{/if}}
</div>
