<!-- 70/30 two-column layout -->
<div class="flex flex-col lg:flex-row gap-8 items-start">

  <!-- ===== LEFT COLUMN: Posts 70% ===== -->
  <section class="w-full lg:w-[70%] min-w-0">
    {{#if posts.length}}
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
      {{#each posts}}
        {{> post-card}}
      {{/each}}
    </div>
    {{> pagination pagination=pagination}}
    {{else}}
    <div class="text-center py-20 text-gray-400">
      <div class="text-5xl mb-4">📝</div>
      <p class="text-base font-medium">Chưa có bài viết nào.</p>
      <p class="text-sm mt-1">Hãy quay lại sau!</p>
    </div>
    {{/if}}
  </section>

  <!-- ===== RIGHT COLUMN: Tags 30% ===== -->
  <aside class="w-full lg:w-[30%] shrink-0">
    {{> sidebar-right tags=tags}}
  </aside>

</div>
