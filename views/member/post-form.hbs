<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">{{#if isEdit}}Edit Post{{else}}New Post{{/if}}</h1>

  {{#if error}}
  <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{{error}}</div>
  {{/if}}

  <form
    method="POST"
    action="{{#if isEdit}}/posts/{{post.id}}?_method=PATCH{{else}}/posts{{/if}}"
    class="bg-white border border-gray-200 rounded-lg p-6 space-y-5"
  >
    <input type="hidden" name="_csrf" value="{{csrfToken}}" />

    <div>
      <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
      <input type="text" id="title" name="title" value="{{#if post}}{{post.title}}{{else}}{{dto.title}}{{/if}}"
        required maxlength="255"
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
    </div>

    <div>
      <label for="body" class="block text-sm font-medium text-gray-700 mb-1">Body</label>
      <textarea id="body" name="body" rows="12" required
        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">{{#if post}}{{post.body}}{{else}}{{dto.body}}{{/if}}</textarea>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Tags</label>
      <div class="flex flex-wrap gap-2">
        {{#each tags}}
        <label class="flex items-center gap-1.5 cursor-pointer">
          <input type="checkbox" name="tagIds" value="{{id}}"
            {{#if (includes ../selectedTagIds id)}}checked{{/if}}
            class="rounded border-gray-300 text-indigo-600" />
          <span class="text-sm text-gray-700">{{name}}</span>
        </label>
        {{/each}}
      </div>
    </div>

    <div class="flex gap-3 pt-2">
      <button type="submit" name="action" value="save_draft"
        class="bg-gray-200 text-gray-800 px-4 py-2 rounded text-sm hover:bg-gray-300">
        Save Draft
      </button>
      <button type="submit" name="action" value="submit_review"
        class="bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700">
        Submit for Review
      </button>
      <a href="/dashboard" class="ml-auto text-sm text-gray-500 hover:text-gray-700 self-center">Cancel</a>
    </div>
  </form>
</div>
