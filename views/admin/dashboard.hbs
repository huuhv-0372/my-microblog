<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Admin Dashboard</h1>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <a href="/admin/posts" class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-md transition-shadow">
      <div class="text-4xl font-bold text-indigo-600 mb-2">{{pendingPosts}}</div>
      <div class="text-gray-600 text-sm">Post{{#unless (eq pendingPosts 1)}}s{{/unless}} pending review</div>
    </a>
    <a href="/admin/comments" class="bg-white border border-gray-200 rounded-lg p-6 hover:shadow-md transition-shadow">
      <div class="text-4xl font-bold text-yellow-600 mb-2">{{pendingComments}}</div>
      <div class="text-gray-600 text-sm">Comment{{#unless (eq pendingComments 1)}}s{{/unless}} awaiting moderation</div>
    </a>
  </div>
</div>
