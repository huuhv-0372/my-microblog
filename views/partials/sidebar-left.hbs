<div class="bg-white rounded-lg border border-gray-200 p-4">
  <h3 class="text-sm font-semibold text-gray-700 mb-3 uppercase tracking-wide">Recent Posts</h3>
  <ol class="space-y-2">
    {{#each recentPosts}}
    <li>
      <a href="/posts/{{slug}}" class="text-sm text-indigo-600 hover:underline line-clamp-2">{{title}}</a>
    </li>
    {{else}}
    <li class="text-sm text-gray-400">No posts yet.</li>
    {{/each}}
  </ol>
</div>
