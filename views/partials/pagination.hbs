{{#if (gt pagination.totalPages 1)}}
<nav class="flex justify-center items-center flex-wrap gap-1.5 mt-8" aria-label="Pagination">
  {{#if pagination.hasPrev}}
  <a href="?page={{subtract pagination.page 1}}" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-100 text-gray-600 font-mono">← Prev</a>
  {{/if}}

  {{#each (range 1 pagination.totalPages)}}
  <a href="?page={{this}}" class="px-3 py-1.5 text-sm border rounded font-mono transition-colors
    {{#if (eq this ../pagination.page)}}bg-gray-900 text-white border-gray-900 font-bold{{else}}border-gray-300 text-gray-600 hover:bg-gray-100{{/if}}">{{this}}</a>
  {{/each}}

  {{#if pagination.hasNext}}
  <a href="?page={{add pagination.page 1}}" class="px-3 py-1.5 text-sm border border-gray-300 rounded hover:bg-gray-100 text-gray-600 font-mono">Next →</a>
  {{/if}}
</nav>
{{/if}}
