      <a href="/tags/nestjs"     class="block px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">Category: NestJS</a>
      <a href="/tags/typescript" class="block px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">Category: TypeScript</a>
      <a href="/tags/tutorial"   class="block px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">Category: Tutorial</a>
      <a href="/about"           class="block px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">About Me</a>
      {{#if user}}
        <a href="/dashboard" class="block px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">Dashboard</a>
        {{#if (eq user.role 'admin')}}
        <a href="/admin" class="block px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">Admin</a>
        {{/if}}
        <form action="/logout" method="POST">
          <input type="hidden" name="_csrf" value="{{csrfToken}}" />
          <button type="submit" class="block w-full text-left px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">Đăng xuất</button>
        </form>
      {{else}}
        <a href="/login"    class="block px-3 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 rounded">Đăng nhập</a>
        <a href="/register" class="block px-3 py-2 text-sm text-yellow-400 hover:text-yellow-300 rounded font-semibold">Đăng ký</a>
      {{/if}}
