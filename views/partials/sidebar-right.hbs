<!-- Tags widget -->
<div class="border border-gray-200 rounded-lg bg-white overflow-hidden">
  <div class="bg-gray-900 text-white px-4 py-3">
    <h3 class="text-xs font-bold uppercase tracking-widest">Tags</h3>
  </div>
  <ul class="divide-y divide-gray-100">
    {{#each tags}}
    <li>
      <a href="/tags/{{slug}}" class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition-colors group">
        <span class="flex items-center gap-2 text-sm text-gray-700 group-hover:text-gray-900">
          <span class="font-mono text-gray-400 text-xs">#</span>
          {{name}}
        </span>
        <span class="text-xs font-mono bg-gray-100 text-gray-500 px-2 py-0.5 rounded group-hover:bg-gray-900 group-hover:text-white transition-colors">
          {{publishedPostCount}}
        </span>
      </a>
    </li>
    {{else}}
    <li class="px-4 py-3 text-sm text-gray-400">Chưa có tag nào.</li>
    {{/each}}
  </ul>
</div>
